# Public hostname (must point at your droplet before TLS will issue)
DOMAIN=home.example.com
ACME_EMAIL=you@example.com

# Flask session signing — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Path to Firebase service account JSON on the host (mounted into the container)
FIREBASE_SERVICE_ACCOUNT_FILE=./secrets/firebase-service-account.json

# Optional
MAX_UPLOAD_MB=50
SESSION_DAYS=14
