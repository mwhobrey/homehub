# Public hostname (for Firebase authorized domains and your Caddy site block)
DOMAIN=home.example.com

# Only needed if you use compose.prod.with-caddy.yml (no existing Caddy)
ACME_EMAIL=you@example.com

# HomeHub bind address (optional localhost debug; Caddy uses Docker network)
HOMEHUB_BIND=127.0.0.1:5000

# Docker network shared with Headscale/Caddy (confirm: docker inspect caddy)
PROXY_NETWORK=reverseproxy-nw

# Flask session signing — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Firebase Admin SDK key on the host (mounted via ./secrets -> /run/secrets in compose)
# Place the JSON at: secrets/firebase-service-account.json

# Optional
MAX_UPLOAD_MB=50
SESSION_DAYS=14
