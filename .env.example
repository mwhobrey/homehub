# Public hostname (for Firebase authorized domains and your Caddy site block)
DOMAIN=home.example.com

# Only needed if you use compose.prod.with-caddy.yml (no existing Caddy)
ACME_EMAIL=you@example.com

# HomeHub bind address (optional localhost debug; Caddy uses Docker network)
HOMEHUB_BIND=127.0.0.1:5000

# Docker network shared with Headscale/Caddy (confirm: docker inspect caddy)
PROXY_NETWORK=reverseproxy-nw

# Flask session signing — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Firebase Admin SDK key (host paths; entrypoint copies into /tmp/firebase-sa.json):
#   secrets/firebase-service-account.json  (preferred)
#   data/firebase-service-account.json     (fallback if secrets/ mount is broken)

# Optional
MAX_UPLOAD_MB=50
SESSION_DAYS=14

# Local dev (run.py): reloader is off by default on Windows (WinError 10038 if forced on)
# FLASK_DEBUG=1
# FLASK_USE_RELOADER=0
# HOMEHUB_DISABLE_BACKGROUND_JOBS=1

# Google Calendar OAuth (when google_calendar.enabled in config.yml)
# Copy from GCP → Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
